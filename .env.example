# === CEX: Binance ===
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# === DEX: Ethereum RPC ===
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key
ETH_PRIVATE_KEY=your_ethereum_private_key
ETH_WALLET_ADDRESS=0xYourWalletAddress

# === Optional: Additional Chains ===
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/your_key
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key

# === MEV Protection ===
FLASHBOTS_RELAY=https://relay.flashbots.net
FLASHBOTS_AUTH_KEY=    # Optional: Flashbots auth key

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Bot Settings ===
BOT_MODE=paper                   # paper | live
MAX_POSITION_SIZE_USD=1000
MIN_PROFIT_THRESHOLD_USD=5
DAILY_LOSS_LIMIT_USD=100
